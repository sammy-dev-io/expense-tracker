# Copy this file, rename the copy to ".env", then fill in your real values.
# Never commit the real ".env" file to GitHub - it holds secrets.

# The connection string MongoDB Atlas gives you when you create a database
MONGO_URI=your_mongodb_connection_string_here

# The port your Express server will run on
PORT=5000

# Your secret key used to sign login tokens (JWT) - make this long and random
JWT_SECRET=any_long_random_string_you_make_up_yourself

# The URL of your deployed frontend, so the backend allows it to make requests.
# Locally this is your Vite dev server; in production, set this to your real
# deployed frontend URL on your hosting platform's environment variables.
CLIENT_URL=http://localhost:5173
